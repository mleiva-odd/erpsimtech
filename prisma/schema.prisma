generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model Company {
  id                    String                @id @default(uuid())
  name                  String
  slug                  String                @unique
  nit                   String?
  email                 String
  phone                 String?
  logoUrl               String?
  active                Boolean               @default(true)
  // Fase 16: régimen tributario del emisor (GENERAL=12% / PEQUEÑO_CONTRIBUYENTE=5%).
  // Nullable hasta que el admin lo elija explícitamente. Sin default — lo regula
  // SAT, no la app. Una vez seteado NO se permite cambio desde la app.
  taxRegime             TaxRegime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  auditLogs             AuditLog[]
  branches              Branch[]
  categories            Category[]
  settings              CompanySettings?
  customers             Customer[]
  inventoryAdjustments  InventoryAdjustment[]
  notifications         Notification[]
  products              Product[]
  purchases             PurchaseOrder[]
  sales                 Sale[]
  stockTransfers        StockTransfer[]
  subscription          Subscription?
  suppliers             Supplier[]
  users                 User[]
  deliveryNotes         DeliveryNote[]
  accountingEntries     AccountingEntry[]
  accountingCategories  AccountingCategory[]
  supplierPayables      SupplierPayable[]
  bankAccounts          BankAccount[]
  customRoles           CustomRole[]
  employees             Employee[]
  payrolls              Payroll[]
  employeeLoans         EmployeeLoan[]
  chartOfAccounts       ChartOfAccount[]
  journalEntries        JournalEntry[]
  accountingPeriods     AccountingPeriod[]
  stockMovements        StockMovement[]
  customerCredits       CustomerCredit[]
  taxSeries             TaxSeries[]
  taxDocuments          TaxDocument[]
  creditNotes           CreditNote[]
  debitNotes            DebitNote[]
  // Fase 22d-5 · Plantillas de documentos reusables (Quote/Sale/RFQ/PO/PR).
  documentTemplates     DocumentTemplate[]
  // Fase 19 · Compras enterprise (PR/RFQ/PO/GRN/Invoice/CreditNote).
  // Umbral mínimo para que una PO requiera aprobación. Default 0 = todas
  // requieren aprobación. Para legacy se setea alto en onboarding.
  purchaseApprovalThreshold Decimal             @default(0) @db.Decimal(10, 2)
  purchaseRequests      PurchaseRequest[]
  rfqRequests           RFQRequest[]
  goodsReceivedNotes    GoodsReceivedNote[]
  supplierInvoices      SupplierInvoice[]
  supplierCreditNotes   SupplierCreditNote[]
  // Fase 20 · Ventas enterprise (QUOTE/ORDER/Delivery/Invoice + listas, promos, cupones, comisiones).
  /// Si la empresa habilita el flujo de cotizaciones. Algunos POS puros no las usan.
  allowQuotes           Boolean              @default(true)
  /// Si la empresa habilita el flujo de pedidos (ORDER) con reserva de stock.
  allowOrders           Boolean              @default(true)
  /// Vigencia default (días) de una cotización antes de expirar.
  quoteValidDays        Int                  @default(30)
  /// Fase 17 (audit decisiones, Crítico #2): umbrales superiores de los buckets
  /// de aging en días, en orden ascendente. Default `[30, 60, 90]` produce los
  /// 4 buckets clásicos (current / d1_30 / d31_60 / d61_90 / d90_plus). Una
  /// PYME que opera distinto puede setear ej. `[15, 30, 45]` o `[30, 60, 90, 120]`.
  agingBucketDays       Int[]                @default([30, 60, 90])
  /// Fase 15 (audit decisiones, Crítico #1): método de costeo de inventario.
  /// GT permite WAC (promedio ponderado) y FIFO (LIFO prohibido tributariamente
  /// desde 2013). Default WAC para PYMEs típicas. Industrias perecederos /
  /// farmacéuticos suelen requerir FIFO obligatorio por vencimiento de lotes.
  costMethod            CostMethod           @default(WAC)
  /// Si la empresa calcula comisiones por venta para vendedores/empleados.
  commissionEnabled     Boolean              @default(false)
  priceLists            PriceList[]
  promotions            Promotion[]
  coupons               Coupon[]
  commissionRules       CommissionRule[]
  commissions           Commission[]
  stockReservations     StockReservation[]
  deliveryNoteSequence  DeliveryNoteSequence?
  // Fase 21 · Multi-moneda. Tabla maestra de tipos de cambio por empresa
  // (currency, date) → rate. Permite snapshot inmutable en cada documento
  // monetario y cálculo de diferencia cambiaria al cobrar/pagar.
  exchangeRates         ExchangeRate[]
}

model Branch {
  id                   String                @id @default(uuid())
  companyId            String
  name                 String
  code                 String
  address              String?
  phone                String?
  isMain               Boolean               @default(false)
  active               Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  auditLogs            AuditLog[]
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cashRegisters        CashRegister[]
  inventoryAdjustments InventoryAdjustment[]
  productStocks        ProductStock[]
  purchases            PurchaseOrder[]       @relation("PurchasesTo")
  sales                Sale[]
  transfersFrom        StockTransfer[]       @relation("TransfersFrom")
  transfersTo          StockTransfer[]       @relation("TransfersTo")
  users                User[]
  userAccess           UserBranchAccess[]
  deliveryNotes        DeliveryNote[]
  accountingEntries    AccountingEntry[]
  employees            Employee[]
  journalEntries       JournalEntry[]
  stockMovements       StockMovement[]
  taxSeries            TaxSeries[]
  taxDocuments         TaxDocument[]
  creditNotes          CreditNote[]
  debitNotes           DebitNote[]
  // Fase 19 · Compras enterprise
  purchaseRequests     PurchaseRequest[]
  rfqRequests          RFQRequest[]
  // Fase 20 · Ventas enterprise
  stockReservations    StockReservation[]

  @@unique([companyId, code])
}

model User {
  id                       String                    @id @default(uuid())
  companyId                String?
  branchId                 String?
  name                     String
  email                    String                    @unique
  password                 String
  role                     Role                      @default(USER)
  active                   Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  accountPayments          AccountPayment[]
  auditLogs                AuditLog[]
  cashRegisters            CashRegister[]
  cashRegisterTransactions CashRegisterTransaction[]
  inventoryAdjustments     InventoryAdjustment[]
  purchases                PurchaseOrder[]
  sales                    Sale[]
  saleReturns              SaleReturn[]
  sessions                 SessionLog[]
  stockTransfers           StockTransfer[]
  branch                   Branch?                   @relation(fields: [branchId], references: [id])
  company                  Company?                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchAccess             UserBranchAccess[]
  deliveryNotes            DeliveryNote[]
  accountingEntries        AccountingEntry[]
  supplierPayables         SupplierPayable[]
  supplierPayments         SupplierPayment[]
  bankTransactions         BankTransaction[]
  employee                 Employee?
  journalEntries           JournalEntry[]
  stockMovements           StockMovement[]
  customerCredits          CustomerCredit[]
  customerCreditApplications CustomerCreditApplication[]
  creditNotes              CreditNote[]
  debitNotes               DebitNote[]
  // Fase 18 · Planilla GT
  payrollsApproved         Payroll[]                 @relation("PayrollApproved")
  payrollsPaid             Payroll[]                 @relation("PayrollPaid")
  empLoansApproved         EmployeeLoan[]            @relation("EmpLoanApproved")
  empLoansCancelled        EmployeeLoan[]            @relation("EmpLoanCancelled")
  // Fase 19 · Compras enterprise
  purchasesApproved        PurchaseOrder[]           @relation("POApproved")
  purchaseRequestsRequested PurchaseRequest[]        @relation("PRRequestedBy")
  purchaseRequestsApproved PurchaseRequest[]         @relation("PRApprovedBy")
  rfqRequestsCreated       RFQRequest[]              @relation("RFQCreatedBy")
  rfqQuotesCreated         RFQQuote[]                @relation("RFQQuoteBy")
  // Fase 22c-4 · RFQs donde este usuario es el comprador asignado
  rfqRequestsAsBuyer       RFQRequest[]              @relation("RFQBuyer")
  // Fase 22d-5 · Plantillas creadas por este usuario.
  documentTemplatesCreated DocumentTemplate[]        @relation("DocumentTemplateCreatedBy")
  goodsReceivedNotes       GoodsReceivedNote[]       @relation("GRNReceivedBy")
  supplierInvoicesRegistered SupplierInvoice[]       @relation("SupInvRegistered")
  supplierCreditNotesRegistered SupplierCreditNote[] @relation("SupCNRegistered")
  // Fase 21 · Multi-moneda
  exchangeRatesCreated      ExchangeRate[]            @relation("ExchangeRateCreatedBy")

  customRoleId             String?
  customRole               CustomRole?               @relation(fields: [customRoleId], references: [id])
}

model CustomRole {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@unique([companyId, name])
}

model UserBranchAccess {
  userId   String
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

model SessionLog {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products    Product[]
  // Fase 20 · Ventas enterprise
  commissionRules CommissionRule[]

  @@unique([companyId, name])
}

model Product {
  id                   String                @id @default(uuid())
  companyId            String
  categoryId           String
  sku                  String
  barcode              String?
  name                 String
  description          String?
  price                Decimal               @db.Decimal(10, 2)
  cost                 Decimal               @db.Decimal(10, 2)
  active               Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  isTaxExempt          Boolean               @default(false)
  unitOfMeasure        UnitOfMeasure         @default(UNIT)
  wholesalePrice       Decimal?              @db.Decimal(10, 2)
  supplierId           String?
  hasVariants          Boolean               @default(false)
  imageUrl             String?
  isBundle             Boolean               @default(false)
  inventoryAdjustments InventoryAdjustment[]
  category             Category              @relation(fields: [categoryId], references: [id])
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier             Supplier?             @relation(fields: [supplierId], references: [id])
  bundleItems          ProductBundleItem[]   @relation("BundleParent")
  partOfBundles        ProductBundleItem[]   @relation("BundleComponent")
  stocks               ProductStock[]
  variants             ProductVariant[]
  purchaseItems        PurchaseOrderItem[]
  saleItems            SaleItem[]
  transferItems        StockTransferItem[]
  deliveryNoteItems    DeliveryNoteItem[]
  stockMovements       StockMovement[]
  // Fase 19 · Compras enterprise
  purchaseRequestItems PurchaseRequestItem[]
  rfqRequestItems      RFQRequestItem[]
  rfqQuoteItems        RFQQuoteItem[]
  // Fase 20 · Ventas enterprise
  priceListItems       PriceListItem[]
  stockReservations    StockReservation[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId, active])
}

model ProductVariant {
  id             String              @id @default(uuid())
  productId      String
  sku            String
  barcode        String?
  name           String
  price          Decimal?            @db.Decimal(10, 2)
  wholesalePrice Decimal?            @db.Decimal(10, 2)
  cost           Decimal?            @db.Decimal(10, 2)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  bundleItems    ProductBundleItem[]
  stocks         ProductStock[]
  product        Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseItems  PurchaseOrderItem[]
  saleItems      SaleItem[]
  transferItems  StockTransferItem[]
  inventoryAdjustments InventoryAdjustment[]
  deliveryNoteItems    DeliveryNoteItem[]
  stockMovements StockMovement[]
  // Fase 19 · Compras enterprise
  purchaseRequestItems PurchaseRequestItem[]
  rfqRequestItems      RFQRequestItem[]
  rfqQuoteItems        RFQQuoteItem[]
  // Fase 20 · Ventas enterprise
  priceListItems       PriceListItem[]
  stockReservations    StockReservation[]

  @@unique([productId, sku])
}

/// Stock tracked per branch. A product has one stock row per branch. // Phase 4: Per branch per Variant
model ProductStock {
  id        String          @id @default(uuid())
  productId String
  branchId  String
  quantity  Int             @default(0)
  minStock  Int             @default(5)
  updatedAt DateTime        @updatedAt
  variantId String?
  branch    Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId, variantId])
  @@index([branchId, quantity])
}


model InventoryAdjustment {
  id          String   @id @default(uuid())
  companyId   String
  branchId    String
  productId   String
  userId      String
  oldQuantity Int
  newQuantity Int
  difference  Int
  variantId   String?
  reason      String
  createdAt   DateTime @default(now())
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([branchId, productId])
  @@index([variantId])
}

model ProductBundleItem {
  id              String          @id @default(uuid())
  bundleProductId String
  componentId     String
  quantity        Int             @default(1)
  variantId       String?
  bundleProduct   Product         @relation("BundleParent", fields: [bundleProductId], references: [id], onDelete: Cascade)
  component       Product         @relation("BundleComponent", fields: [componentId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([bundleProductId, componentId, variantId])
}

model Supplier {
  id          String            @id @default(uuid())
  companyId   String
  name        String
  contactName String?
  email       String?
  phone       String?
  nit         String?
  address     String?
  active      Boolean           @default(true)
  // Fase 17: días de crédito que ofrece este proveedor. Reemplaza el hardcoded
  // de +30 días en el handler de compras (`src/app/api/purchases/route.ts`).
  creditDaysDefault Int          @default(30)
  // Fase 19 · Régimen tributario y retenciones GT
  /// Régimen tributario del proveedor (mismo enum que Fase 16). Null hasta
  /// que se clasifique. GENERAL = factura con IVA 12%; PEQUENO_CONTRIBUYENTE
  /// = sin IVA crédito, posible retención IVA 5% si la empresa es Agente.
  taxRegime         TaxRegime?
  /// Indica si la empresa retiene IVA al pagar facturas de este proveedor.
  /// Aplica típicamente cuando proveedor es PC y la empresa es Agente de
  /// Retención del IVA (5%). También cubre Agente del IVA general (15%) si
  /// la empresa fue calificada por SAT.
  withholdsIVA      Boolean      @default(false)
  /// Indica si se retiene ISR por servicios profesionales en cada factura
  /// (5%-7% según tramo SAT). La empresa debe declarar y pagar la retención.
  withholdsISR      Boolean      @default(false)
  /// Tasa ISR aplicada cuando withholdsISR=true. Default 5%; usuario sube a
  /// 7% si la facturación mensual del proveedor supera el tramo SAT.
  isrRate           Decimal      @default(0.05) @db.Decimal(5, 4)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  products    Product[]
  purchases   PurchaseOrder[]
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payables    SupplierPayable[]
  // Fase 19 · Relaciones nuevas
  purchaseRequests    PurchaseRequest[]
  rfqQuotes           RFQQuote[]           @relation("RFQQuoteSupplier")
  supplierInvoices    SupplierInvoice[]
  supplierCreditNotes SupplierCreditNote[]
  // Fase 22c-4 · RFQ workflow expansion
  rfqInvitations      RFQInvitation[]      @relation("RFQInvitations")
  rfqItemAwards       RFQRequestItem[]     @relation("RFQItemAwardedSupplier")

  @@unique([companyId, nit])
  @@unique([companyId, name])
}

model PurchaseOrder {
  id         String              @id @default(uuid())
  companyId  String
  branchId   String
  supplierId String
  userId     String
  reference  String?
  total      Decimal             @db.Decimal(10, 2)
  status     PurchaseStatus      @default(COMPLETED)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  // Fase 19 · campos enterprise
  /// Subtotal de la PO antes de IVA y retenciones. Nullable para no romper
  /// PO legacy (los registros viejos quedan con subtotal=null y total como
  /// fuente de verdad).
  subtotal              Decimal? @db.Decimal(10, 2)
  /// IVA total estimado al crear la PO. Se recalcula al registrar el
  /// SupplierInvoice. 0 si proveedor es Pequeño Contribuyente (sin crédito).
  tax                   Decimal? @default(0) @db.Decimal(10, 2)
  /// Retención IVA estimada al pagar (5% Pequeño Contribuyente o 15%
  /// Agente). Se recalcula al registrar el SupplierInvoice.
  withheldIVA           Decimal? @default(0) @db.Decimal(10, 2)
  /// Retención ISR servicios profesionales (5% o 7%) — solo si proveedor
  /// withholdsISR=true.
  withheldISR           Decimal? @default(0) @db.Decimal(10, 2)
  /// Costo adicional (flete, seguro, aduana) prorrateado al inventario al
  /// recibir. No genera asiento aparte; suma al COGS efectivo del GRN.
  landedCost            Decimal? @default(0) @db.Decimal(10, 2)
  approvedById          String?
  approvedAt            DateTime?
  receivedAt            DateTime?
  /// Número de la factura del proveedor — denormalizado para listados.
  /// La fuente de verdad sigue siendo `SupplierInvoice.invoiceNumber`.
  invoiceNumber         String?
  /// Snapshot del régimen tributario del proveedor al crear la PO. Permite
  /// auditar la decisión de retención posterior.
  taxRegime             TaxRegime?
  // Fase 21 · Multi-moneda. Snapshot inmutable del tipo de cambio al emitir la PO.
  currency              String   @default("GTQ")
  exchangeRate          Decimal? @db.Decimal(18, 8)
  functionalAmount      Decimal? @db.Decimal(15, 2)
  branch     Branch              @relation("PurchasesTo", fields: [branchId], references: [id])
  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  user       User                @relation(fields: [userId], references: [id])
  items      PurchaseOrderItem[]
  payable    SupplierPayable?
  approvedBy            User?    @relation("POApproved", fields: [approvedById], references: [id])
  purchaseRequestId     String?  @unique
  purchaseRequest       PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  goodsReceivedNotes    GoodsReceivedNote[]
  supplierInvoice       SupplierInvoice?
  // Fase 22c-4 · trazabilidad RFQ → PO (split award puede generar N POs por RFQ)
  sourceRfqId           String?
  sourceRfq             RFQRequest? @relation("RFQGeneratedPOs", fields: [sourceRfqId], references: [id])
}

model PurchaseOrderItem {
  id              String          @id @default(uuid())
  purchaseOrderId String
  productId       String
  // Fase 19 · Decimal(12,3) para granel (kg, libras, litros, galones).
  quantity        Decimal         @db.Decimal(12, 3)
  unitCost        Decimal         @db.Decimal(10, 2)
  subtotal        Decimal         @db.Decimal(10, 2)
  variantId       String?
  // Fase 22d-5 · orden visual del item dentro de la PO (drag-drop).
  sortOrder       Int             @default(0)
  /// Cantidad acumulada efectivamente recibida (sum de GRN items).
  quantityReceived Decimal        @default(0) @db.Decimal(12, 3)
  /// Cantidad acumulada facturada (sum de SupplierInvoice items en el
  /// futuro; hoy se setea al registrar el SupplierInvoice por la línea
  /// completa, ya que cada PO factura 1 vez).
  quantityInvoiced Decimal        @default(0) @db.Decimal(12, 3)
  /// IVA aplicable a esta línea. 0 = exento o régimen PC. Se persiste para
  /// poder dividir IVA crédito en facturas con líneas mixtas.
  taxRate         Decimal         @default(0) @db.Decimal(5, 4)
  product         Product         @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  grnItems        GoodsReceivedNoteItem[]
}

model Customer {
  id              String           @id @default(uuid())
  companyId       String
  name            String
  email           String?
  phone           String?
  nit             String?
  address         String?
  creditLimit     Decimal          @default(0) @db.Decimal(10, 2)
  balance         Decimal          @default(0) @db.Decimal(10, 2)
  // Fase 17: configuración de crédito por cliente.
  // creditDaysDefault: días que se otorgan automáticamente al vender a crédito.
  // maxOverdueDays: tolerancia antes de bloquear nuevas ventas a crédito.
  creditDaysDefault Int            @default(30)
  maxOverdueDays    Int            @default(30)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accountPayments AccountPayment[]
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales           Sale[]
  deliveryNotes   DeliveryNote[]
  customerCredits CustomerCredit[]
  // Fase 20 · Ventas enterprise
  priceLists      CustomerPriceList[]
  couponRedemptions CouponRedemption[]
}

model AccountPayment {
  id             String        @id @default(uuid())
  customerId     String
  userId         String
  cashRegisterId String?
  bankAccountId  String?
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  reference      String?
  notes          String?
  status         String        @default("COMPLETED") // COMPLETED | VOID
  // Fase 21 · Multi-moneda. Snapshot al recibir el abono.
  currency         String   @default("GTQ")
  exchangeRate     Decimal? @db.Decimal(18, 8)
  functionalAmount Decimal? @db.Decimal(15, 2)
  createdAt      DateTime      @default(now())
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id])
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])
  bankAccount    BankAccount?  @relation(fields: [bankAccountId], references: [id])
}

model Sale {
  id             String        @id @default(uuid())
  companyId      String
  branchId       String
  userId         String
  customerId     String?
  cashRegisterId String?
  clientRequestId String?
  invoiceNumber  String?
  subtotal       Decimal       @db.Decimal(10, 2)
  discount       Decimal       @default(0) @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  status         SaleStatus    @default(COMPLETED)
  channel        SaleChannel   @default(POS)
  // Fase 17: dueDate solo se setea en ventas a crédito (Payment.method=CREDIT).
  // Ventas contado tienen dueDate=null y nunca se marcan OVERDUE.
  dueDate        DateTime?
  // Fase 16 · Snapshot del receptor al momento de la venta. SAT exige que el
  // NIT figure inmutable en el DTE certificado, aunque el cliente lo cambie
  // después en su master. "CF" representa Consumidor Final.
  customerNit    String?
  customerName   String?
  // Snapshot del régimen tributario vigente del emisor al momento de emitir.
  taxRegime      TaxRegime?
  // Fase 20 · Ciclo enterprise. Snapshots para auditoría:
  /// Fecha de expiración de la cotización (QUOTE). Se setea = createdAt + Company.quoteValidDays.
  expiresAt      DateTime?
  /// Momento en que la cotización fue aceptada (QUOTE → ORDER).
  acceptedAt     DateTime?
  /// Lista de precios snapshot al crear la venta. Nullable: si no se aplicó, queda null.
  priceListId    String?
  /// Código de cupón aplicado a la venta (snapshot). El registro de redención
  /// está en CouponRedemption (1:1 con la venta).
  couponCode     String?
  /// Vendedor asignado a la venta (para comisión). Default = userId, pero puede
  /// ser distinto al usuario que tipea (caja vs vendedor).
  salesUserId    String?
  // Fase 21 · Multi-moneda. Snapshot inmutable del tipo de cambio al emitir.
  // `currency` es ISO-3 (GTQ por default). `exchangeRate` = 1 si currency=GTQ.
  // `functionalAmount` = total * exchangeRate (siempre en GTQ, para reportes SAT).
  currency         String   @default("GTQ")
  exchangeRate     Decimal? @db.Decimal(18, 8)
  functionalAmount Decimal? @db.Decimal(15, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  payments       Payment[]
  branch         Branch        @relation(fields: [branchId], references: [id])
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])
  company        Company       @relation(fields: [companyId], references: [id])
  customer       Customer?     @relation(fields: [customerId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  items          SaleItem[]
  returns        SaleReturn[]
  deliveryNotes  DeliveryNote[]
  customerCreditApplications CustomerCreditApplication[]
  taxDocument    TaxDocument?
  creditNotes    CreditNote[]
  debitNotes     DebitNote[]
  // Fase 20 · Ventas enterprise
  priceList         PriceList?         @relation(fields: [priceListId], references: [id])
  stockReservations StockReservation[]
  couponRedemption  CouponRedemption?
  commissions       Commission[]

  @@unique([companyId, invoiceNumber])
  @@unique([companyId, clientRequestId])
  @@index([companyId, status, createdAt])
  @@index([branchId, status, createdAt])
  @@index([companyId, channel])
}

model SaleReturn {
  id         String   @id @default(uuid())
  saleId     String
  userId     String
  reason     String
  amount     Decimal  @db.Decimal(10, 2)
  stockAdded Boolean  @default(true)
  createdAt  DateTime @default(now())
  items      SaleReturnItem[]
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@index([saleId, createdAt])
}

model SaleReturnItem {
  id           String     @id @default(uuid())
  saleReturnId String
  saleItemId   String
  quantity     Int
  amount       Decimal    @db.Decimal(10, 2)
  saleItem     SaleItem   @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)

  @@index([saleReturnId])
  @@index([saleItemId])
}

model SaleItem {
  id        String          @id @default(uuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal         @db.Decimal(10, 2)
  unitCost  Decimal?        @db.Decimal(10, 2)
  discount  Decimal         @default(0) @db.Decimal(10, 2)
  // Fase 22d-5 · orden visual del item dentro de la venta (drag-drop).
  // Default 0 para registros legacy; el backfill ROW_NUMBER asigna orden
  // estable por id. Lecturas usan `orderBy: { sortOrder: 'asc' }`.
  sortOrder Int             @default(0)
  // Fase 20 · Tasa de descuento por línea (0..1). Permite registrar el % en
  // adición al monto absoluto en `discount` (que sigue siendo el descuento
  // efectivo en GTQ aplicado a la línea, para fines contables).
  discountRate Decimal      @default(0) @db.Decimal(5, 4)
  subtotal  Decimal         @db.Decimal(10, 2)
  // Fase 16 · Cálculo de IVA por línea. `taxRate` es el porcentaje vigente al
  // momento de la venta (0 si exento, 0.12 régimen General, 0.05 Pequeño
  // Contribuyente). `tax` es el monto en GTQ. Backfill 0 en históricos —
  // ninguna venta legacy se recalcula.
  taxRate   Decimal         @default(0) @db.Decimal(5, 4)
  tax       Decimal         @default(0) @db.Decimal(10, 2)
  variantId String?
  product   Product         @relation(fields: [productId], references: [id])
  returnItems SaleReturnItem[]
  creditNoteItems CreditNoteItem[]
  sale      Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
}

/// Separate payments table allows mixed payments (split between cash + card, etc.)
model Payment {
  id        String        @id @default(uuid())
  saleId    String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  reference String?
  bankAccountId String?
  // Fase 21 · Multi-moneda. Snapshot del tipo de cambio al momento del pago.
  // Cuando currency != Sale.currency aplica diferencia cambiaria.
  currency         String   @default("GTQ")
  exchangeRate     Decimal? @db.Decimal(18, 8)
  functionalAmount Decimal? @db.Decimal(15, 2)
  createdAt DateTime      @default(now())
  sale      Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
}

model CashRegister {
  id             String                    @id @default(uuid())
  branchId       String
  userId         String
  openingBalance Decimal                   @db.Decimal(10, 2)
  closingBalance Decimal?                  @db.Decimal(10, 2)
  status         String                    @default("OPEN")
  openedAt       DateTime                  @default(now())
  closedAt       DateTime?
  branch         Branch                    @relation(fields: [branchId], references: [id])
  user           User                      @relation(fields: [userId], references: [id])
  transactions   CashRegisterTransaction[]
  sales          Sale[]
  customerPayments AccountPayment[]
}

model CashRegisterTransaction {
  id             String       @id @default(uuid())
  cashRegisterId String
  userId         String
  type           PayoutType   @default(EXPENSE)
  amount         Decimal      @db.Decimal(10, 2)
  description    String
  reference      String?
  createdAt      DateTime     @default(now())
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
}

model CompanySettings {
  id                String      @id @default(uuid())
  companyId         String      @unique
  storeName         String      @default("Mi Empresa POS")
  address           String?
  phone             String?
  nit               String?
  receiptMsg        String?     @default("¡Gracias por su compra!")
  felEnabled        Boolean     @default(false)
  felProvider       FelProvider @default(NONE)
  felNitEmisor      String?
  felApiUser        String?
  felApiKey         String?
  felCertificateUrl String?
  acceptsCash       Boolean     @default(true)
  acceptsCard       Boolean     @default(true)
  acceptsTransfer   Boolean     @default(true)
  acceptsCredit     Boolean     @default(false)
  taxRate           Decimal     @default(0.12) @db.Decimal(5, 4)
  taxIncluded       Boolean     @default(true)
  currency          String      @default("GTQ")
  currencySymbol    String      @default("Q")
  updatedAt         DateTime    @updatedAt
  company           Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                 String             @id @default(uuid())
  companyId          String             @unique
  plan               String             @default("trial")
  status             SubscriptionStatus @default(TRIAL)
  price              Decimal            @default(0) @db.Decimal(10, 2)
  maxBranches        Int                @default(1)
  maxUsersPerBranch  Int                @default(3)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  paymentProviderId  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  branchId  String?
  userId    String?
  entity    String
  entityId  String
  action    String
  changes   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  branch    Branch?  @relation(fields: [branchId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([companyId, entity])
  @@index([companyId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  companyId String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isRead])
}

model StockTransfer {
  id           String              @id @default(uuid())
  companyId    String
  fromBranchId String
  toBranchId   String
  userId       String
  reference    String?
  status       TransferStatus      @default(COMPLETED)
  createdAt    DateTime            @default(now())
  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromBranch   Branch              @relation("TransfersFrom", fields: [fromBranchId], references: [id])
  toBranch     Branch              @relation("TransfersTo", fields: [toBranchId], references: [id])
  user         User                @relation(fields: [userId], references: [id])
  items        StockTransferItem[]
}

model StockTransferItem {
  id              String          @id @default(uuid())
  stockTransferId String
  productId       String
  quantity        Int
  variantId       String?
  product         Product         @relation(fields: [productId], references: [id])
  transfer        StockTransfer   @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
}

enum Role {
  SUPER_ADMIN
  USER
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT
}

enum SaleStatus {
  COMPLETED
  PENDING
  CANCELLED
  QUOTE
  // Fase 17: el cron diario `markOverdueDocuments` setea OVERDUE cuando
  // dueDate < now() y queda saldo pendiente. Idempotente.
  OVERDUE
  // Fase 20 · Ciclo enterprise QUOTE → ORDER → PARTIALLY_DELIVERED → DELIVERED → INVOICED.
  // COMPLETED queda como atajo POS (one-shot: factura+entrega+cobro). PENDING ya no se usa.
  ORDER
  PARTIALLY_DELIVERED
  DELIVERED
  INVOICED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
}

// Provider de certificación FEL.
// Fase 16: se agrega `MOCK` para desarrollo/staging (genera DTE local sin
// llamar a un servicio real). Los providers reales (INFILE/DIGIFACT) quedan
// como stubs hasta que se contraten credenciales.
//
// Nota: este enum lo llaman `FelProvider` en el schema. El brief de Fase 16
// menciona `FelProviderType` — mantenemos el nombre actual para evitar
// renombrar/migrar el enum existente (lección Fase 17: ALTER TYPE RENAME es
// disruptivo). El alias semántico `FelProviderType` se expone en código TS
// en `src/lib/fel/types.ts`.
enum FelProvider {
  NONE
  MOCK
  INFILE
  DIGIFACT
}

enum AccountType {
  CASH_BOX
  BANK_ACCOUNT
  CREDIT_CARD
  DIGITAL_WALLET
}

enum UnitOfMeasure {
  UNIT
  KG
  LB
  LITER
  GALLON
  BOX
}

enum PurchaseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  INVOICED
  COMPLETED // legacy — backfill mapea PO antiguas aquí o a INVOICED.
  CANCELLED
}

enum PayoutType {
  EXPENSE
  WITHDRAWAL
  REFUND
}

enum NotificationType {
  INFO
  WARNING
  ERROR
}

enum TransferStatus {
  COMPLETED
  PENDING
  CANCELLED
}

enum SaleChannel {
  POS
  REMOTE
  WEB
}

enum AccountingType {
  INCOME
  EXPENSE
}

enum DeliveryNoteStatus {
  PENDING
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum PayableStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

// ─────────────────────────────────────────
// Notas de Envío
// ─────────────────────────────────────────

/// Nota de envío / despacho para entregas a clientes
model DeliveryNote {
  id            String              @id @default(uuid())
  companyId     String
  branchId      String
  saleId        String?
  customerId    String?
  userId        String
  noteNumber    String?
  recipientName String
  address       String
  phone         String?
  notes         String?
  status        DeliveryNoteStatus  @default(PENDING)
  dispatchedAt  DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch              @relation(fields: [branchId], references: [id])
  sale          Sale?               @relation(fields: [saleId], references: [id])
  customer      Customer?           @relation(fields: [customerId], references: [id])
  user          User                @relation(fields: [userId], references: [id])
  items         DeliveryNoteItem[]

  @@unique([companyId, noteNumber])
  @@index([companyId, status])
  @@index([saleId])
}

model DeliveryNoteItem {
  id              String          @id @default(uuid())
  deliveryNoteId  String
  productId       String
  variantId       String?
  quantity        Int
  deliveryNote    DeliveryNote    @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
}

// ─────────────────────────────────────────
// Contabilidad Operativa
// ─────────────────────────────────────────

/// Categorías contables configurables por empresa
model AccountingCategory {
  id          String          @id @default(uuid())
  companyId   String
  name        String
  type        AccountingType
  isSystem    Boolean         @default(false)
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries     AccountingEntry[]

  @@unique([companyId, name])
}

/// Entrada contable — cada movimiento financiero del negocio
/// DEPRECATED (Fase 14): este modelo single-line se mantiene únicamente por
/// retro-compatibilidad durante la migración a partida doble (JournalEntry).
/// Los nuevos movimientos contables se generan vía `createJournalEntry` en
/// `src/lib/accounting/journal.ts`. Una migración futura (Fase 25) dropea
/// AccountingEntry/AccountingCategory después de validar la migración.
model AccountingEntry {
  id            String             @id @default(uuid())
  companyId     String
  branchId      String?
  categoryId    String
  type          AccountingType
  description   String
  amount        Decimal            @db.Decimal(10, 2)
  referenceType String?
  referenceId   String?
  date          DateTime           @default(now())
  userId        String
  bankTransactionId String?
  migrated      Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  category      AccountingCategory @relation(fields: [categoryId], references: [id])
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?            @relation(fields: [branchId], references: [id])
  user          User               @relation(fields: [userId], references: [id])
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id])

  @@index([companyId, type, date])
  @@index([companyId, categoryId])
  @@index([referenceType, referenceId])
}

// ─────────────────────────────────────────
// Cuentas por Pagar a Proveedores
// ─────────────────────────────────────────

/// Cuentas por pagar a proveedores (crédito con proveedores)
model SupplierPayable {
  id            String          @id @default(uuid())
  companyId     String
  supplierId    String
  purchaseId    String?         @unique
  userId        String
  description   String
  totalAmount   Decimal         @db.Decimal(10, 2)
  paidAmount    Decimal         @default(0) @db.Decimal(10, 2)
  status        PayableStatus   @default(PENDING)
  dueDate       DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  purchase      PurchaseOrder?  @relation(fields: [purchaseId], references: [id])
  user          User            @relation(fields: [userId], references: [id])
  payments      SupplierPayment[]

  @@index([companyId, status])
  @@index([supplierId])
}

/// Pagos / abonos a proveedores
model SupplierPayment {
  id            String          @id @default(uuid())
  payableId     String
  userId        String
  amount        Decimal         @db.Decimal(10, 2)
  method        PaymentMethod
  reference     String?
  notes         String?
  status        String          @default("COMPLETED") // COMPLETED | VOID
  bankAccountId String?
  // Fase 21 · Multi-moneda. Snapshot al ejecutar el pago al proveedor.
  currency         String   @default("GTQ")
  exchangeRate     Decimal? @db.Decimal(18, 8)
  functionalAmount Decimal? @db.Decimal(15, 2)
  createdAt     DateTime        @default(now())

  payable       SupplierPayable @relation(fields: [payableId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id])
  bankAccount   BankAccount?    @relation(fields: [bankAccountId], references: [id])
}

// ─────────────────────────────────────────
// Tesorería y Bancos
// ─────────────────────────────────────────

model BankAccount {
  id             String            @id @default(uuid())
  companyId      String
  name           String            // ej: "Banrural Monetario", "Caja Fuerte Interna"
  type           AccountType       @default(BANK_ACCOUNT)
  accountNumber  String?
  currency       String            @default("GTQ")
  balance        Decimal           @default(0) @db.Decimal(15, 2)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions   BankTransaction[]
  payments       Payment[]
  accountPayments AccountPayment[]
  supplierPayments SupplierPayment[]

  @@index([companyId, type])
}

model BankTransaction {
  id             String            @id @default(uuid())
  bankAccountId  String
  userId         String
  type           AccountingType    // INCOME or EXPENSE
  amount         Decimal           @db.Decimal(15, 2)
  reference      String?
  description    String?
  reconciled     Boolean           @default(false)
  // Fase 21 · Multi-moneda. Hereda la currency de BankAccount al crear y
  // snapshotea el rate del día. `functionalAmount` es el equivalente GTQ.
  currency         String   @default("GTQ")
  exchangeRate     Decimal? @db.Decimal(18, 8)
  functionalAmount Decimal? @db.Decimal(15, 2)
  createdAt      DateTime          @default(now())

  bankAccount    BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id])
  accountingEntries AccountingEntry[]

  @@index([bankAccountId, type])
}

// ─────────────────────────────────────────
// Recursos Humanos (HR) y Planillas
// ─────────────────────────────────────────

model Employee {
  id              String           @id @default(uuid())
  companyId       String
  branchId        String?
  userId          String?          @unique // Link to system user if they have one
  firstName       String
  lastName        String
  email           String?
  phone           String?
  documentId      String?          // DPI en Guatemala
  nit             String?
  address         String?
  position        String?          // Cargo/Puesto
  baseSalary      Decimal          @db.Decimal(10, 2)
  hireDate        DateTime
  terminationDate DateTime?
  active          Boolean          @default(true)
  bankAccount     String?
  bankName        String?
  // Fase 18: parámetros configurables por empleado (no son ley, son
  // configuración de la empresa).
  payrollFrequency PayrollFrequency @default(MONTHLY)
  shift            Shift            @default(DIURNA)
  /// Bonificación incentivo (decreto 78-89): default Q250 pero la empresa
  /// puede pagar más. Es prorrateable al período (quincenal = mitad).
  bonusIncentive   Decimal          @default(250.00) @db.Decimal(10, 2)
  /// Si la empresa contrata bajo afiliación al IGSS. Empleados no afiliados
  /// (ej. temporales) no descuentan ni reciben cuotas IGSS laboral/patronal.
  igssAffiliated   Boolean          @default(true)
  /// Número de afiliación IGSS (para reportes CSV IGSS-FORMUL-1117).
  igssNumber       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch          Branch?          @relation(fields: [branchId], references: [id])
  user            User?            @relation(fields: [userId], references: [id])
  payrollItems    PayrollItem[]
  attendance      Attendance[]
  leaveRequests   LeaveRequest[]
  loans           EmployeeLoan[]
  balance         EmployeeBalance?
  // Fase 20 · Ventas enterprise
  commissions     Commission[]

  @@index([companyId])
}

/// Frecuencia de planilla. Determina divisor base para prorrateo de
/// bonificación incentivo y periodicidad de provisiones.
enum PayrollFrequency {
  MONTHLY
  BIWEEKLY    // quincenal
}

/// Tipo de jornada. Afecta horas base por jornada ordinaria (LGT art 116):
///   DIURNA   → 8 hrs/día
///   NOCTURNA → 6 hrs/día
///   MIXTA    → 7 hrs/día
enum Shift {
  DIURNA
  NOCTURNA
  MIXTA
}

model Payroll {
  id              String           @id @default(uuid())
  companyId       String
  name            String           // e.g., "Planilla Mayo 2026 - Primera Quincena"
  startDate       DateTime
  endDate         DateTime
  status          PayrollStatus    @default(DRAFT)
  totalGross      Decimal          @db.Decimal(10, 2)
  totalDeductions Decimal          @db.Decimal(10, 2)
  totalNet        Decimal          @db.Decimal(10, 2)
  // Fase 18: tipado por concepto (regular vs Bono14 vs aguinaldo, etc.)
  payrollType     PayrollType      @default(REGULAR)
  /// Referencia normalizada del período fiscal. Ej:
  ///   REGULAR     → "2026-06" / "2026-06-Q1"
  ///   BONO14      → "2026-BONO14"
  ///   AGUINALDO   → "2026-AGUINALDO"
  ///   INDEMNIZACION → "EMP-<id>-2026-05"
  periodReference String?
  approvedAt      DateTime?
  paidAt          DateTime?
  approvedById    String?
  paidById        String?
  /// FK al asiento contable generado al pagar (idempotencia). Único.
  journalEntryId  String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items           PayrollItem[]
  approvedBy      User?            @relation("PayrollApproved", fields: [approvedById], references: [id])
  paidBy          User?            @relation("PayrollPaid", fields: [paidById], references: [id])
  journalEntry    JournalEntry?    @relation("PayrollJournal", fields: [journalEntryId], references: [id])

  @@index([companyId])
  @@index([companyId, payrollType, periodReference])
}

/// Tipo de planilla. Determina helpers de cálculo y plantilla de asiento
/// contable que se genera al pagar.
enum PayrollType {
  REGULAR        // planilla mensual/quincenal
  BONO14         // Bono 14, pagado en julio
  AGUINALDO      // Aguinaldo, pagado en diciembre
  INDEMNIZACION  // liquidación al despido
  EXTRAORDINARIA // ajuste manual
}

model PayrollItem {
  id              String           @id @default(uuid())
  payrollId       String
  employeeId      String
  // Snapshots del empleado al momento de generar la planilla. Si después
  // cambia baseSalary del empleado, este snapshot NO se mueve (auditoría).
  baseSalary      Decimal          @db.Decimal(10, 2)
  bonusIncentive  Decimal          @default(0) @db.Decimal(10, 2)
  /// Días efectivamente trabajados / hábiles del período (proporciona).
  daysWorked      Int              @default(30)
  // Horas extras del período (3 tipos, snapshot de los rates aplicados):
  overtimeRegularHours  Decimal    @default(0) @db.Decimal(8, 2)  // 50% premium
  overtimeRegularAmount Decimal    @default(0) @db.Decimal(10, 2)
  overtimeNightHours    Decimal    @default(0) @db.Decimal(8, 2)  // 100% premium
  overtimeNightAmount   Decimal    @default(0) @db.Decimal(10, 2)
  overtimeHolidayHours  Decimal    @default(0) @db.Decimal(8, 2)  // 100%
  overtimeHolidayAmount Decimal    @default(0) @db.Decimal(10, 2)
  /// Pago séptimo día (jornada 6 días/sem) — Art. 126 CT GT.
  seventhDayAmount      Decimal    @default(0) @db.Decimal(10, 2)
  commissions           Decimal    @default(0) @db.Decimal(10, 2)
  otherBonuses          Decimal    @default(0) @db.Decimal(10, 2)
  /// Bruto: sumar ordinario + bonificación + horas extras + comisiones + otros.
  totalGross            Decimal    @db.Decimal(10, 2)
  // Deducciones del empleado (positivas):
  igssLaboral           Decimal    @default(0) @db.Decimal(10, 2)  // 4.83% sobre base + h.extras
  /// (legacy compat) alias mantenido para no romper queries antiguas.
  /// Nuevo código usa `igssLaboral`. Misma cifra.
  igss                  Decimal    @default(0) @db.Decimal(10, 2)
  isr                   Decimal    @default(0) @db.Decimal(10, 2)
  loanDeduction         Decimal    @default(0) @db.Decimal(10, 2)
  otherDeductions       Decimal    @default(0) @db.Decimal(10, 2)
  totalDeductions       Decimal    @default(0) @db.Decimal(10, 2)
  netSalary             Decimal    @db.Decimal(10, 2)
  // Provisiones (NO se descuentan al empleado, son costo patronal mensual):
  bono14Provision         Decimal  @default(0) @db.Decimal(10, 2)
  aguinaldoProvision      Decimal  @default(0) @db.Decimal(10, 2)
  indemnizacionProvision  Decimal  @default(0) @db.Decimal(10, 2)
  vacacionesProvision     Decimal  @default(0) @db.Decimal(10, 2)
  // Cargas patronales (IGSS 10.67% + IRTRA 1% + INTECAP 1% = 12.67%):
  igssPatronal            Decimal  @default(0) @db.Decimal(10, 2)
  irtra                   Decimal  @default(0) @db.Decimal(10, 2)
  intecap                 Decimal  @default(0) @db.Decimal(10, 2)
  totalCostoPatronal      Decimal  @default(0) @db.Decimal(10, 2)
  notes                   String?

  payroll         Payroll          @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employee        Employee         @relation(fields: [employeeId], references: [id])

  @@index([payrollId])
  @@index([employeeId])
}

/// Préstamos al empleado (anticipo, descontado mensualmente del salario).
/// La cuota se descuenta en cada planilla REGULAR mientras esté ACTIVE,
/// hasta saldar `balance`. Cancelable.
model EmployeeLoan {
  id              String        @id @default(uuid())
  companyId       String
  employeeId      String
  /// Monto original prestado.
  amount          Decimal       @db.Decimal(10, 2)
  /// Saldo pendiente (decrementa con cada cuota aplicada).
  balance         Decimal       @db.Decimal(10, 2)
  /// Cuota a descontar en cada planilla mensual.
  monthlyDeduction Decimal      @db.Decimal(10, 2)
  status          EmployeeLoanStatus @default(ACTIVE)
  reason          String?
  approvedById    String
  approvedAt      DateTime      @default(now())
  cancelledAt     DateTime?
  cancelledById   String?
  notes           String?

  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee      @relation(fields: [employeeId], references: [id])
  approvedBy      User          @relation("EmpLoanApproved", fields: [approvedById], references: [id])
  cancelledBy     User?         @relation("EmpLoanCancelled", fields: [cancelledById], references: [id])

  @@index([companyId, employeeId])
  @@index([companyId, status])
}

enum EmployeeLoanStatus {
  ACTIVE
  PAID
  CANCELLED
}

/// Saldo de vacaciones del empleado.
/// 15 días hábiles por año cumplido (LGT art. 130). Se acumula y se
/// descuenta al gozar (LeaveRequest VACATION aprobado) o al liquidar.
model EmployeeBalance {
  id              String   @id @default(uuid())
  employeeId      String   @unique
  /// Días devengados acumulados sin gozar (positivo).
  vacationDaysAccrued  Decimal @default(0) @db.Decimal(6, 2)
  /// Días tomados desde hireDate (acumulado histórico).
  vacationDaysTaken    Decimal @default(0) @db.Decimal(6, 2)
  updatedAt       DateTime @updatedAt

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

model Attendance {
  id              String           @id @default(uuid())
  employeeId      String
  date            DateTime
  checkIn         DateTime?
  checkOut        DateTime?
  status          AttendanceStatus @default(PRESENT)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([date])
}

model LeaveRequest {
  id              String           @id @default(uuid())
  employeeId      String
  type            LeaveType
  startDate       DateTime
  endDate         DateTime
  reason          String?
  status          LeaveStatus      @default(PENDING)
  approvedById    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HOLIDAY
}

enum LeaveType {
  VACATION
  SICK_LEAVE
  PERSONAL_DAYS
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// Sprint 2.B.2 · Rate limit de login.
// Cada intento se registra para contar fallos por (email, IP) en ventana móvil
// de 15 minutos. NO contiene la contraseña intentada — solo el resultado.
model LoginAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  ipAddress String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt(sort: Desc)])
  @@index([ipAddress, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────
// Contabilidad real (Fase 14): Plan de cuentas + Partida doble
// ─────────────────────────────────────────

/// Plan de cuentas (Chart of Accounts) jerárquico por empresa.
/// Códigos en formato decimal "1.1.01" (ej. estándar GT).
/// Solo cuentas con `isPosting=true` aceptan líneas de JournalEntry.
model ChartOfAccount {
  id          String           @id @default(uuid())
  companyId   String
  code        String
  name        String
  type        AccountType2
  parentId    String?
  parent      ChartOfAccount?  @relation("Tree", fields: [parentId], references: [id])
  children    ChartOfAccount[] @relation("Tree")
  isPosting   Boolean          @default(true)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines       JournalLine[]

  @@unique([companyId, code])
  @@index([companyId, type])
  @@index([parentId])
}

/// Tipo contable de cuenta. Se llama `AccountType2` porque el enum
/// `AccountType` legacy (CASH_BOX/BANK_ACCOUNT/...) ya está ocupado por
/// `BankAccount`. Fase 25 puede renombrar cuando se dropee el legacy.
enum AccountType2 {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

/// Período contable mensual. Cuando un período está CLOSED, no se permiten
/// nuevos asientos con fecha dentro del período (helper retorna 409).
model AccountingPeriod {
  id         String       @id @default(uuid())
  companyId  String
  year       Int
  month      Int
  status     PeriodStatus @default(OPEN)
  closedAt   DateTime?
  closedById String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries    JournalEntry[]

  @@unique([companyId, year, month])
  @@index([companyId, status])
}

enum PeriodStatus {
  OPEN
  CLOSED
}

/// Cabecera de asiento contable (partida doble).
/// Las líneas suman DR == CR (validado por `createJournalEntry`).
/// `posted`: true para asientos generados por sistema; false (DRAFT) para
/// asientos manuales que requieren publicación explícita.
model JournalEntry {
  id            String           @id @default(uuid())
  companyId     String
  branchId      String?
  periodId      String
  date          DateTime
  description   String
  referenceType String?
  referenceId   String?
  userId        String
  posted        Boolean          @default(true)
  postedAt      DateTime?
  reversedById  String?          @unique
  reversedEntry JournalEntry?    @relation("Reversal", fields: [reversedById], references: [id])
  reversedBy    JournalEntry[]   @relation("Reversal")
  createdAt     DateTime         @default(now())

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?          @relation(fields: [branchId], references: [id])
  period        AccountingPeriod @relation(fields: [periodId], references: [id])
  user          User             @relation(fields: [userId], references: [id])
  lines         JournalLine[]
  /// Fase 18: relación inversa para Payroll → JournalEntry (1:1).
  payroll       Payroll?         @relation("PayrollJournal")

  @@index([companyId, date])
  @@index([companyId, posted])
  @@index([periodId])
  @@index([referenceType, referenceId])
}

/// Línea de asiento. Debe tener `debit` o `credit` > 0 pero no ambos.
/// La cuenta referenciada debe tener `isPosting=true`.
model JournalLine {
  id           String         @id @default(uuid())
  journalId    String
  accountId    String
  debit        Decimal        @default(0) @db.Decimal(15, 2)
  credit       Decimal        @default(0) @db.Decimal(15, 2)
  description  String?
  costCenterId String?

  journal      JournalEntry   @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([journalId])
}

// ─────────────────────────────────────────
// Inventario · Movimientos y costeo (Fase 15)
// ─────────────────────────────────────────

/// Log unificado de movimientos de inventario (Fase 15).
/// Toda alteración de stock (compras, ventas, ajustes, traslados, devoluciones,
/// stock inicial, etc.) genera UNA fila en esta tabla con `quantity` firmada:
///   - quantity > 0  → entrada (PURCHASE, ADJUSTMENT_IN, TRANSFER_IN, RETURN_FROM_CUSTOMER, COUNT_DIFFERENCE+).
///   - quantity < 0  → salida  (SALE, ADJUSTMENT_OUT, TRANSFER_OUT, RETURN_TO_SUPPLIER, COUNT_DIFFERENCE-).
/// `balanceAfter` y `costAfter` son snapshots inmutables del estado del SKU
/// inmediatamente después del movimiento. El kardex es un simple
/// `SELECT * FROM StockMovement ORDER BY date` — no reconstruye desde 5 tablas.
model StockMovement {
  id            String   @id @default(uuid())
  companyId     String
  productId     String
  variantId     String?
  branchId      String
  type          StockMovementType
  quantity      Decimal  @db.Decimal(15, 3)
  unitCost      Decimal  @db.Decimal(15, 4)
  balanceAfter  Decimal  @db.Decimal(15, 3)
  costAfter     Decimal  @db.Decimal(15, 4)
  referenceType String
  referenceId   String
  date          DateTime @default(now())
  userId        String
  notes         String?
  createdAt     DateTime @default(now())

  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  branch        Branch          @relation(fields: [branchId], references: [id])
  user          User            @relation(fields: [userId], references: [id])

  @@index([companyId, productId, date])
  @@index([companyId, branchId, date])
  @@index([referenceType, referenceId])
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_OUT
  TRANSFER_IN
  RETURN_FROM_CUSTOMER
  RETURN_TO_SUPPLIER
  COUNT_DIFFERENCE
}

// ─────────────────────────────────────────
// Crédito de Cliente · Anticipos y saldos a favor (Fase 17)
// ─────────────────────────────────────────

/// Saldo a favor del cliente. Se origina por:
///   - ADVANCE_PAYMENT: el cliente paga antes de una venta (anticipo).
///   - SALE_RETURN: devolución de mercadería que deja saldo crédito.
///   - MANUAL_CREDIT: ajuste manual (ej. nota de crédito comercial).
///
/// `amount` es el monto original; `balance` decrementa al aplicarse a ventas
/// posteriores vía CustomerCreditApplication. Cuando balance llega a 0 → FULLY_APPLIED.
model CustomerCredit {
  id            String                @id @default(uuid())
  companyId     String
  customerId    String
  amount        Decimal               @db.Decimal(10, 2)
  balance       Decimal               @db.Decimal(10, 2)
  status        CustomerCreditStatus  @default(ACTIVE)
  reason        CustomerCreditReason
  referenceType String?
  referenceId   String?
  notes         String?
  userId        String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer              @relation(fields: [customerId], references: [id])
  user          User                  @relation(fields: [userId], references: [id])
  applications  CustomerCreditApplication[]

  @@index([companyId, customerId])
  @@index([companyId, status])
}

enum CustomerCreditStatus {
  ACTIVE
  PARTIALLY_APPLIED
  FULLY_APPLIED
  CANCELLED
}

enum CustomerCreditReason {
  ADVANCE_PAYMENT
  SALE_RETURN
  MANUAL_CREDIT
}

/// Aplicación de un crédito a una venta específica. Permite aplicar parcial
/// (un crédito de Q500 aplicado Q300 a Sale A y Q200 a Sale B).
/// La suma de `amount` por customerCreditId debe = customerCredit.amount.
model CustomerCreditApplication {
  id               String         @id @default(uuid())
  customerCreditId String
  saleId           String
  amount           Decimal        @db.Decimal(10, 2)
  userId           String
  appliedAt        DateTime       @default(now())

  customerCredit   CustomerCredit @relation(fields: [customerCreditId], references: [id])
  sale             Sale           @relation(fields: [saleId], references: [id])
  user             User           @relation(fields: [userId], references: [id])

  @@index([customerCreditId])
  @@index([saleId])
}

// ─────────────────────────────────────────
// Facturación Electrónica · FEL (Fase 16)
// ─────────────────────────────────────────

/// Régimen tributario del emisor (Company).
/// - GENERAL: IVA 12%, con derecho a crédito fiscal.
/// - PEQUEÑO_CONTRIBUYENTE: IVA 5%, sin crédito fiscal (el 5% NO es IVA
///   débito recuperable contablemente — es parte del ingreso).
enum TaxRegime {
  GENERAL
  PEQUENO_CONTRIBUYENTE
}

/// Tipos de Documento Tributario Electrónico (DTE) SAT.
enum TaxDocumentType {
  FACT  // Factura
  NCRE  // Nota de Crédito
  NDEB  // Nota de Débito
}

/// Estado del DTE en el ciclo de certificación.
enum TaxDocumentStatus {
  PENDING    // En proceso de certificación
  CERTIFIED  // Certificado por SAT/provider
  REJECTED   // Provider rechazó la certificación
  CANCELLED  // Anulado (con NCRE asociada)
}

/// Serie de correlativos por sucursal y tipo de DTE. SAT asigna una serie
/// + rango por sucursal autorizada. La empresa lo registra acá. `nextNumber`
/// se incrementa atómicamente al certificar (lock optimista vía updateMany
/// con `where: nextNumber = X` para garantizar unicidad sin race).
model TaxSeries {
  id            String          @id @default(uuid())
  companyId     String
  branchId      String
  documentType  TaxDocumentType
  prefix        String          // ej "A", "FACT-2026"
  nextNumber    Int             @default(1)
  rangeFrom     Int?            // límite inferior autorizado por SAT
  rangeTo       Int?            // límite superior autorizado por SAT
  authorization String?         // número de autorización SAT
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch          @relation(fields: [branchId], references: [id])
  documents     TaxDocument[]

  @@unique([companyId, branchId, documentType, prefix])
  @@index([companyId, documentType])
}

/// Cabecera del DTE certificado. Se crea PENDING, se certifica con el
/// provider (Mock/Infile/Digifact), queda CERTIFIED con UUID y XML firmado.
/// Anulación crea NCRE asociada vía `cancelledById` y marca CANCELLED.
///
/// Snapshots inmutables al momento de certificar:
///   - `receptorNit`/`receptorNombre`: si el cliente edita su NIT/nombre
///     después, el DTE conserva el original (requisito SAT).
///   - `emisorNit`/`emisorNombre`: idem.
///   - `taxRegime`: si la empresa cambia régimen, el DTE conserva el vigente
///     al emitir.
///   - `seriePrefix`/`numero`: el correlativo asignado al certificar.
model TaxDocument {
  id                   String            @id @default(uuid())
  companyId            String
  branchId             String
  seriesId             String
  type                 TaxDocumentType
  seriePrefix          String            // snapshot del prefix al certificar
  numero               Int               // correlativo asignado
  numeroDisplay        String            // ej "A-000123" para UI
  status               TaxDocumentStatus @default(PENDING)
  // Snapshot del receptor
  receptorNit          String            // "CF" para Consumidor Final
  receptorNombre       String
  // Snapshot del emisor
  emisorNit            String
  emisorNombre         String
  // Régimen al momento de la certificación
  taxRegime            TaxRegime
  // Provider que certificó
  provider             FelProvider
  // Respuesta del provider
  dteUuid              String?           // UUID asignado por SAT
  autorizacion         String?
  fechaCertificacion   DateTime?
  hashCertificacion    String?
  xmlFirmado           String?
  providerResponseJson Json?
  // Vínculos a documentos
  saleId               String?           @unique
  creditNoteId         String?           @unique
  debitNoteId          String?           @unique
  // NCRE anuladora (si el DTE fue anulado)
  cancelledById        String?           @unique
  cancelledBy          TaxDocument?      @relation("Cancellation", fields: [cancelledById], references: [id])
  cancellations        TaxDocument[]     @relation("Cancellation")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  company              Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch               Branch            @relation(fields: [branchId], references: [id])
  series               TaxSeries         @relation(fields: [seriesId], references: [id])
  sale                 Sale?             @relation(fields: [saleId], references: [id])
  creditNote           CreditNote?       @relation(fields: [creditNoteId], references: [id])
  debitNote            DebitNote?        @relation(fields: [debitNoteId], references: [id])

  @@unique([companyId, branchId, seriePrefix, numero])
  @@index([companyId, type, status])
  @@index([companyId, fechaCertificacion])
}

/// Nota de Crédito. Anula o ajusta una venta certificada. Reversa el efecto
/// contable y fiscal del DTE original (Sale → JournalEntry contrario al
/// certificarse). Lleva su propio asiento al ser certificada.
model CreditNote {
  id           String           @id @default(uuid())
  companyId    String
  saleId       String           // venta original a anular/ajustar
  branchId     String
  userId       String
  reason       String           // motivo legal de la NCRE
  subtotal     Decimal          @db.Decimal(10, 2)
  tax          Decimal          @db.Decimal(10, 2)
  total        Decimal          @db.Decimal(10, 2)
  taxRegime    TaxRegime
  items        CreditNoteItem[]
  taxDocument  TaxDocument?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale         Sale             @relation(fields: [saleId], references: [id])
  branch       Branch           @relation(fields: [branchId], references: [id])
  user         User             @relation(fields: [userId], references: [id])

  @@index([companyId, saleId])
}

model CreditNoteItem {
  id           String     @id @default(uuid())
  creditNoteId String
  saleItemId   String?    // si es anulación de una línea específica
  productId    String
  variantId    String?
  description  String
  quantity     Int
  unitPrice    Decimal    @db.Decimal(10, 2)
  taxRate      Decimal    @db.Decimal(5, 4)
  subtotal     Decimal    @db.Decimal(10, 2)
  tax          Decimal    @db.Decimal(10, 2)
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  saleItem     SaleItem?  @relation(fields: [saleItemId], references: [id])
}

/// Nota de Débito. Ajuste hacia arriba (recargos, intereses por mora) sobre
/// una venta certificada.
model DebitNote {
  id           String          @id @default(uuid())
  companyId    String
  saleId       String
  branchId     String
  userId       String
  reason       String
  subtotal     Decimal         @db.Decimal(10, 2)
  tax          Decimal         @db.Decimal(10, 2)
  total        Decimal         @db.Decimal(10, 2)
  taxRegime    TaxRegime
  items        DebitNoteItem[]
  taxDocument  TaxDocument?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale         Sale            @relation(fields: [saleId], references: [id])
  branch       Branch          @relation(fields: [branchId], references: [id])
  user         User            @relation(fields: [userId], references: [id])

  @@index([companyId, saleId])
}

model DebitNoteItem {
  id          String    @id @default(uuid())
  debitNoteId String
  productId   String?   // opcional para conceptos puros (intereses)
  description String    // ej "Recargo por mora"
  quantity    Int
  unitPrice   Decimal   @db.Decimal(10, 2)
  taxRate     Decimal   @db.Decimal(5, 4)
  subtotal    Decimal   @db.Decimal(10, 2)
  tax         Decimal   @db.Decimal(10, 2)
  debitNote   DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// Fase 19 · Compras enterprise: PR → RFQ → PO → GRN → SupplierInvoice
// ─────────────────────────────────────────

/// Solicitud de compra interna (Purchase Request).
/// Un empleado solicita comprar algo; un aprobador lo convierte a PO.
model PurchaseRequest {
  id            String   @id @default(uuid())
  companyId     String
  branchId      String
  supplierId    String?  // opcional: la PR puede no especificar proveedor todavía
  requestedById String
  reason        String
  status        PurchaseRequestStatus @default(PENDING)
  approvedById  String?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  rejectionReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch   @relation(fields: [branchId], references: [id])
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  requestedBy   User     @relation("PRRequestedBy", fields: [requestedById], references: [id])
  approvedBy    User?    @relation("PRApprovedBy", fields: [approvedById], references: [id])
  items         PurchaseRequestItem[]
  purchaseOrder PurchaseOrder?

  @@index([companyId, status])
}

enum PurchaseRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CONVERTED_TO_PO
  CANCELLED
}

model PurchaseRequestItem {
  id                String  @id @default(uuid())
  purchaseRequestId String
  productId         String
  variantId         String?
  quantity          Decimal @db.Decimal(12, 3)
  estimatedUnitCost Decimal? @db.Decimal(10, 2)
  notes             String?
  // Fase 22d-5 · orden visual del item dentro de la PR (drag-drop).
  sortOrder         Int     @default(0)

  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id])
  variant           ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([purchaseRequestId, sortOrder])
}

/// Request For Quotation: pedir cotización a varios proveedores.
/// Cada RFQ tiene N cotizaciones (RFQQuote). El comprador puede adjudicar
/// la quote ganadora ENTERA (flujo legacy via awardedQuoteId) o adjudicar
/// item por item a distintos proveedores (split award via
/// RFQRequestItem.awardedSupplierId, Fase 22c-4).
model RFQRequest {
  id             String @id @default(uuid())
  companyId      String
  branchId       String
  reason         String
  createdById    String
  /// DRAFT → SENT → CLOSED/AWARDED/CANCELLED. OPEN se mantiene como sinónimo
  /// deprecado de SENT para compatibilidad con datos previos a Fase 22c-4.
  status         RFQStatus @default(DRAFT)
  closedAt       DateTime?
  awardedQuoteId String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  // Fase 22c-4 · operacional
  /// Identificador legible "RFQ-YYYY-NNN" generado al pasar de DRAFT a SENT.
  reference         String?
  /// Fecha límite para que los proveedores envíen cotización.
  responseDeadline  DateTime?
  /// Días de validez esperados de cada cotización (snapshot al SEND;
  /// default se hereda de Company.quoteValidDays).
  quoteValidityDays Int?
  /// Texto libre del lugar de entrega (puede ser branch.name o address).
  deliveryPlace     String?
  /// Comprador responsable (puede diferir de createdBy en empresas grandes).
  buyerId           String?
  /// Timestamp de la transición DRAFT → SENT.
  sentAt            DateTime?

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch         Branch   @relation(fields: [branchId], references: [id])
  createdBy      User     @relation("RFQCreatedBy", fields: [createdById], references: [id])
  buyer          User?    @relation("RFQBuyer", fields: [buyerId], references: [id])
  awardedQuote   RFQQuote? @relation("RFQAwarded", fields: [awardedQuoteId], references: [id])
  items          RFQRequestItem[]
  quotes         RFQQuote[]
  invitations    RFQInvitation[]
  generatedPurchaseOrders PurchaseOrder[] @relation("RFQGeneratedPOs")

  @@index([companyId, status])
  @@index([buyerId])
  @@index([responseDeadline])
}

enum RFQStatus {
  DRAFT
  OPEN
  SENT
  AWARDED
  CANCELLED
  CLOSED
}

model RFQRequestItem {
  id             String  @id @default(uuid())
  rfqRequestId   String
  productId      String
  variantId      String?
  quantity       Decimal @db.Decimal(12, 3)
  specifications String?  // ej "marca específica, calibre, etc."
  // Fase 22c-4 · split award por item
  /// Unidad de medida override (ej "kg", "u", "lb"). Si null, se usa la del producto.
  unit               String?
  /// Notas adicionales para el proveedor sobre este item puntual.
  observations       String?
  /// Proveedor adjudicado para este item (null = no adjudicado todavía).
  awardedSupplierId  String?
  /// Línea específica del RFQQuote ganador (precio + lead time snapshot).
  awardedQuoteItemId String?
  /// Timestamp de la adjudicación.
  awardedAt          DateTime?
  // Fase 22d-5 · orden visual del item dentro del RFQ (drag-drop).
  sortOrder          Int             @default(0)

  rfqRequest        RFQRequest    @relation(fields: [rfqRequestId], references: [id], onDelete: Cascade)
  product           Product       @relation(fields: [productId], references: [id])
  variant           ProductVariant? @relation(fields: [variantId], references: [id])
  awardedSupplier   Supplier?     @relation("RFQItemAwardedSupplier", fields: [awardedSupplierId], references: [id])
  awardedQuoteItem  RFQQuoteItem? @relation("RFQItemAwardedQuoteItem", fields: [awardedQuoteItemId], references: [id])

  @@index([awardedSupplierId])
}

model RFQQuote {
  id           String  @id @default(uuid())
  rfqRequestId String
  supplierId   String
  quotedById   String   // quien capturó la cotización
  totalAmount  Decimal @db.Decimal(10, 2)
  validUntil   DateTime?
  notes        String?
  selected     Boolean @default(false)
  createdAt    DateTime @default(now())

  rfqRequest   RFQRequest @relation(fields: [rfqRequestId], references: [id], onDelete: Cascade)
  supplier     Supplier @relation("RFQQuoteSupplier", fields: [supplierId], references: [id])
  quotedBy     User     @relation("RFQQuoteBy", fields: [quotedById], references: [id])
  awardedRfq   RFQRequest? @relation("RFQAwarded")
  items        RFQQuoteItem[]
}

model RFQQuoteItem {
  id           String  @id @default(uuid())
  rfqQuoteId   String
  productId    String
  variantId    String?
  quantity     Decimal @db.Decimal(12, 3)
  unitPrice    Decimal @db.Decimal(10, 2)
  deliveryDays Int?

  rfqQuote     RFQQuote @relation(fields: [rfqQuoteId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  awardedToItems RFQRequestItem[] @relation("RFQItemAwardedQuoteItem")
}

/// Invitación enviada a un proveedor (registrado o externo) para que cotice
/// un RFQ. Sirve para saber quién no respondió. Fase 22c-4.
model RFQInvitation {
  id            String   @id @default(uuid())
  rfqRequestId  String
  /// Supplier registrado en la empresa. Null si se invita por email externo
  /// (proveedor no registrado todavía).
  supplierId    String?
  /// Email del proveedor externo (alternativo a supplierId).
  externalEmail String?
  /// Timestamp en que se envió la invitación.
  sentAt        DateTime?
  /// Timestamp en que el proveedor respondió (primera cotización registrada).
  respondedAt   DateTime?
  /// Timestamp si el proveedor declinó explícitamente (opcional).
  declinedAt    DateTime?
  notes         String?
  createdAt     DateTime @default(now())

  rfqRequest    RFQRequest @relation(fields: [rfqRequestId], references: [id], onDelete: Cascade)
  supplier      Supplier?  @relation("RFQInvitations", fields: [supplierId], references: [id])

  // Unicidad enforzada vía índice único parcial en la migración SQL:
  // UNIQUE (rfqRequestId, supplierId) WHERE supplierId IS NOT NULL.
  @@index([rfqRequestId])
  @@index([supplierId])
}

/// Fase 22d-5 · Plantilla reusable de documentos transaccionales.
/// Permite a cualquier usuario de la empresa (con permisos) guardar un set
/// de productos+cantidades+notas como plantilla y aplicarla al crear una
/// nueva Quote/Sale/RFQ/PO/PR. Items en JSONB porque cada `type` define su
/// propio shape mínimo y la plantilla es un snapshot inmutable.
model DocumentTemplate {
  id           String               @id @default(uuid())
  companyId    String
  type         DocumentTemplateType
  name         String
  description  String?
  /// items: Array<{ productId, variantId?, quantity, notes?, unit?, ... }>
  /// Shape mínimo por tipo definido en `src/lib/templates/types.ts`.
  items        Json                 @default("[]")
  /// metadata opcional (deliveryPlace, paymentTerms, etc. específicos por tipo).
  metadata     Json?
  createdById  String
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User                 @relation("DocumentTemplateCreatedBy", fields: [createdById], references: [id])

  // Unicidad por (company, type, name) sólo entre activas — enforce via
  // índice único parcial creado en la migración SQL.
  @@index([companyId, type])
  @@index([createdById])
}

enum DocumentTemplateType {
  QUOTE
  SALE
  RFQ
  PURCHASE_ORDER
  PURCHASE_REQUEST
}

/// Goods Received Note: documento de recepción de mercadería contra una PO.
/// Una PO puede tener N GRNs (recepción parcial). Cada GRN actualiza stock
/// (vía recordStockMovement) y avanza el estado de la PO.
model GoodsReceivedNote {
  id              String   @id @default(uuid())
  companyId       String
  purchaseOrderId String
  receivedById    String
  receivedAt      DateTime @default(now())
  notes           String?

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receivedBy      User     @relation("GRNReceivedBy", fields: [receivedById], references: [id])
  items           GoodsReceivedNoteItem[]

  @@index([companyId, purchaseOrderId])
}

model GoodsReceivedNoteItem {
  id                  String  @id @default(uuid())
  grnId               String
  purchaseOrderItemId String
  quantityReceived    Decimal @db.Decimal(12, 3)
  unitCost            Decimal @db.Decimal(10, 2)  // del PO o ajuste
  notes               String?

  grn                 GoodsReceivedNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poItem              PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
}

/// Factura del proveedor (documento de cobro). Solo 1 por PO usualmente.
/// El SupplierPayable se crea cuando se registra el SupplierInvoice (no
/// cuando se crea la PO).
model SupplierInvoice {
  id              String   @id @default(uuid())
  companyId       String
  purchaseOrderId String   @unique
  supplierId      String
  registeredById  String
  invoiceNumber   String
  invoiceDate     DateTime
  dueDate         DateTime
  subtotal        Decimal  @db.Decimal(10, 2)
  tax             Decimal  @db.Decimal(10, 2)
  withheldIVA     Decimal  @default(0) @db.Decimal(10, 2)
  withheldISR     Decimal  @default(0) @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)  // subtotal + tax - withheldIVA - withheldISR
  attachmentUrl   String?  // PDF/imagen de la factura
  // Fase 21 · Multi-moneda. Snapshot al registrar la factura de proveedor.
  currency         String   @default("GTQ")
  exchangeRate     Decimal? @db.Decimal(18, 8)
  functionalAmount Decimal? @db.Decimal(15, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  registeredBy    User     @relation("SupInvRegistered", fields: [registeredById], references: [id])
  creditNotes     SupplierCreditNote[]

  @@unique([companyId, supplierId, invoiceNumber])
  @@index([companyId, invoiceDate])
}

/// Nota de Crédito del proveedor: descuento o devolución.
model SupplierCreditNote {
  id                String   @id @default(uuid())
  companyId         String
  supplierId        String
  supplierInvoiceId String?  // opcional, puede ser nota independiente
  registeredById    String
  noteNumber        String
  noteDate          DateTime
  reason            String
  subtotal          Decimal  @db.Decimal(10, 2)
  tax               Decimal  @db.Decimal(10, 2)
  total             Decimal  @db.Decimal(10, 2)
  attachmentUrl     String?
  createdAt         DateTime @default(now())

  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier          Supplier @relation(fields: [supplierId], references: [id])
  supplierInvoice   SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id])
  registeredBy      User     @relation("SupCNRegistered", fields: [registeredById], references: [id])

  @@unique([companyId, supplierId, noteNumber])
}

// ─────────────────────────────────────────
// Fase 20 · Ventas enterprise (QUOTE/ORDER/DELIVERED/INVOICED + listas, promos, cupones, comisiones)
// ─────────────────────────────────────────

/// Lista de precios por mayoreo, retail, cliente especial, etc.
model PriceList {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  description String?
  isDefault   Boolean    @default(false)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items       PriceListItem[]
  customers   CustomerPriceList[]
  sales       Sale[]

  @@unique([companyId, name])
  @@index([companyId, active])
}

model PriceListItem {
  id          String  @id @default(uuid())
  priceListId String
  productId   String
  variantId   String?
  price       Decimal @db.Decimal(10, 2)
  priceList   PriceList       @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([priceListId, productId, variantId])
}

/// Asignación N..N de listas de precios a clientes.
model CustomerPriceList {
  customerId  String
  priceListId String
  assignedAt  DateTime  @default(now())
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@id([customerId, priceListId])
}

/// Reserva de stock cuando se crea ORDER. Mantiene apartado hasta entrega/cancelación.
/// `quantity` puede ser fraccional (granel). `releasedAt` se setea al consumir
/// (entrega) o liberar (cancelación). Mientras `releasedAt IS NULL` la reserva
/// está activa y debe restarse del stock disponible.
model StockReservation {
  id          String   @id @default(uuid())
  companyId   String
  saleId      String
  productId   String
  variantId   String?
  branchId    String
  quantity    Decimal  @db.Decimal(15, 3)
  reservedAt  DateTime @default(now())
  releasedAt  DateTime?
  reason      String?
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale        Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  branch      Branch          @relation(fields: [branchId], references: [id])

  @@index([companyId, productId, branchId])
  @@index([saleId])
}

/// Promoción: 2x1 (BUY_N_GET_M), descuento porcentual (PERCENTAGE_OFF) o precio
/// fijo (FIXED_PRICE). Aplicable global o a productos específicos.
model Promotion {
  id                   String        @id @default(uuid())
  companyId            String
  name                 String
  type                 PromotionType
  minPurchase          Decimal?      @db.Decimal(10, 2)
  applicableProductIds String[]
  quantityRequired     Int?
  quantityFree         Int?
  discountRate         Decimal?      @db.Decimal(5, 4)
  fixedPrice           Decimal?      @db.Decimal(10, 2)
  startsAt             DateTime
  endsAt               DateTime
  active               Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  company              Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, active, startsAt, endsAt])
}

enum PromotionType {
  BUY_N_GET_M
  PERCENTAGE_OFF
  FIXED_PRICE
}

/// Método de costeo de inventario (Fase 15 audit decisiones, Crítico #1).
/// Configurable por empresa. WAC = promedio ponderado; FIFO = primero
/// entrado, primero salido. LIFO está prohibido tributariamente en GT
/// (Decreto 10-2012 art. 14) — no se soporta.
enum CostMethod {
  WAC
  FIFO
}

/// Cupón canjeable por descuento.
model Coupon {
  id               String   @id @default(uuid())
  companyId        String
  code             String
  type             CouponType
  amount           Decimal? @db.Decimal(10, 2)
  percentage       Decimal? @db.Decimal(5, 4)
  maxUses          Int?
  usedCount        Int      @default(0)
  perCustomerLimit Int?
  minPurchase      Decimal? @db.Decimal(10, 2)
  validFrom        DateTime
  validUntil       DateTime
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  redemptions      CouponRedemption[]

  @@unique([companyId, code])
  @@index([companyId, active])
}

enum CouponType {
  FIXED_AMOUNT
  PERCENTAGE_OFF
}

model CouponRedemption {
  id         String   @id @default(uuid())
  couponId   String
  saleId     String   @unique
  customerId String?
  redeemedAt DateTime @default(now())
  amount     Decimal  @db.Decimal(10, 2)
  coupon     Coupon    @relation(fields: [couponId], references: [id])
  sale       Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id])

  @@index([couponId])
}

/// Regla de comisiones. Si `categoryId` es null aplica a todos los productos.
/// `basis` decide si la comisión se calcula sobre margen (subtotal - cost) o
/// sobre subtotal.
model CommissionRule {
  id          String          @id @default(uuid())
  companyId   String
  name        String
  categoryId  String?
  basis       CommissionBasis @default(MARGIN)
  rate        Decimal         @db.Decimal(5, 4)
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category    Category?       @relation(fields: [categoryId], references: [id])
  commissions Commission[]

  @@index([companyId, active])
}

enum CommissionBasis {
  MARGIN
  SUBTOTAL
}

/// Comisión generada al INVOICED. Se paga al procesar planilla del período.
model Commission {
  id            String           @id @default(uuid())
  companyId     String
  ruleId        String
  saleId        String
  employeeId    String?
  amount        Decimal          @db.Decimal(10, 2)
  status        CommissionStatus @default(ACCRUED)
  paidAt        DateTime?
  payrollItemId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rule          CommissionRule   @relation(fields: [ruleId], references: [id])
  sale          Sale             @relation(fields: [saleId], references: [id])
  employee      Employee?        @relation(fields: [employeeId], references: [id])

  @@index([companyId, status])
  @@index([saleId])
}

enum CommissionStatus {
  ACCRUED
  PAID
  CANCELLED
}

/// Secuencia atómica para `DeliveryNote.noteNumber` por empresa.
/// Se reserva con updateMany ... where nextNumber=X para evitar race.
model DeliveryNoteSequence {
  id         String   @id @default(uuid())
  companyId  String   @unique
  nextNumber Int      @default(1)
  prefix     String   @default("ND-")
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// Fase 21 · Multi-moneda
// ─────────────────────────────────────────

/// Tipo de cambio histórico de una currency extranjera contra la moneda
/// funcional de la empresa (GTQ). Se utiliza para:
///   1. Snapshot inmutable en cada documento monetario al emitirse
///      (Sale.exchangeRate, Payment.exchangeRate, etc.).
///   2. Calcular `functionalAmount` (= amount × rate) que es el equivalente
///      en GTQ para reportería SAT.
///   3. Calcular diferencia cambiaria al cobrar o pagar (FX_GAIN / FX_LOSS)
///      contra el rate snapshoteado en la factura original.
///
/// Reglas:
///   - `currency` ISO-3 letras mayúsculas (USD, EUR, MXN, etc.).
///   - `rate` = unidades de moneda funcional por 1 unidad de `currency`.
///     Ej.: 1 USD = 7.85 GTQ → rate = 7.85.
///   - `(companyId, currency, date)` único: máximo un rate por día por moneda
///     por empresa. Si Banguat reporta dos tipos, gana el último insertado.
///   - `source` indica origen: MANUAL (admin lo subió), BANGUAT (scraper
///     oficial), API (provider externo terceros). En Fase 21 solo MANUAL se
///     usa operacionalmente; los otros quedan como enum future-ready.
model ExchangeRate {
  id          String             @id @default(uuid())
  companyId   String
  currency    String             // ISO 3 letras (USD, EUR, etc.)
  date        DateTime           @db.Date
  rate        Decimal            @db.Decimal(18, 8) // 1 unidad de `currency` = `rate` GTQ
  source      ExchangeRateSource @default(MANUAL)
  notes       String?
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User               @relation("ExchangeRateCreatedBy", fields: [createdById], references: [id])

  @@unique([companyId, currency, date])
  @@index([companyId, date])
  @@index([companyId, currency, date])
}

enum ExchangeRateSource {
  MANUAL
  BANGUAT
  API
}
