# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# .env.test apunta a la DB efímera de docker-compose.test.yml (puerto 5433)
# y NO contiene secretos reales; se commitea para que cualquier dev/CI
# levante integration tests sin configuración extra.
!.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Logs y archivos temporales de desarrollo
*.log
terminal.txt
/scratch/

# Carpeta de mockup de rediseño — dos patrones para cubrir macOS NFD/NFC.
# El nombre tiene 'ñ' que en HFS+/APFS macOS suele codificarse como n + combining tilde,
# por eso ambos patrones.
Rediseñar landing y login/
Redise*landing y login/

# Reportes y resultados de tests (auto-generados)
/playwright-report/
/test-results/
/coverage/

# Artefactos de auditoría / agentes / IDEs
/.agent/
.audit-*
get_admin.js

# Archivos sensibles que NUNCA deben commitearse
credentials.md
*.credentials
*.secret
secrets/
vercel_production.env

# Archivos de propuesta/marketing en raíz (mover a /docs/marketing si aplica)
/Propuesta_SIMTECH_POS.*
/SIMTECH_POS_Blueprint.md
/fondo*.jpeg
/fondo*.jpg
/simtechlogo.*
/logo.png
/productos_prueba_*.csv

