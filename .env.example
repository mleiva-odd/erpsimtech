# ─────────────────────────────────────────
# Base de datos (Supabase Postgres)
# ─────────────────────────────────────────
# DATABASE_URL usa el connection pooler (pgbouncer) en transaction mode.
# Fase 13: se recomienda apuntar al role `app_user` (sin BYPASSRLS) una
# vez activado. Ver docs/operations/credentials-rotation.md.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL apunta al role privilegiado (postgres) — usado SOLO para correr
# migrations (prisma migrate deploy). NUNCA usarla desde un handler de Next.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────
# NextAuth (sesiones)
# ─────────────────────────────────────────
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="https://erp.simtechgt.com"

# ─────────────────────────────────────────
# Supabase Storage
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-your-service-role-key"

# ─────────────────────────────────────────
# Sentry (errores + performance) — Fase 13
# ─────────────────────────────────────────
# DSN público — embebido en el bundle del cliente. Vacío = Sentry deshabilitado.
NEXT_PUBLIC_SENTRY_DSN=""
# DSN privado del server. Si no está, cae al público.
SENTRY_DSN=""
# Solo build de prod en Vercel. Permite subir source maps.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Identifica el deploy en Sentry (auto-poblar con commit SHA o VERCEL_GIT_COMMIT_SHA).
SENTRY_RELEASE=""
NEXT_PUBLIC_SENTRY_RELEASE=""

# ─────────────────────────────────────────
# Email transaccional (Resend) — Fase 31a
# ─────────────────────────────────────────
# Si vacíos, la app loguea los emails en consola (ConsoleEmailProvider) —
# útil en dev/CI. Para producción real con cliente, contratá Resend
# (https://resend.com — free tier 100/día, 3000/mes) y completá ambas vars.
# Requiere ADEMÁS: instalar `resend` (npm i resend) y verificar el dominio
# remitente en Resend (DKIM/SPF) — sin verificación los emails caen en spam.
RESEND_API_KEY=""
# Default sender — usar dirección del dominio verificado.
# Formato: "Nombre Visible <correo@tudominio.com>".
EMAIL_FROM=""

# ─────────────────────────────────────────
# Password reset — Fase 31b
# ─────────────────────────────────────────
# Validez del token de reseteo en minutos. Default 30 si vacío.
# Trade-off: más corto = más seguro, más largo = mejor UX si el email se atrasa.
PASSWORD_RESET_TTL_MINUTES="30"

# ─────────────────────────────────────────
# Cron de mantenimiento — Fase 38
# ─────────────────────────────────────────
# Secret aleatorio que debe coincidir con el secret CRON_SECRET configurado en
# GitHub Actions (Settings → Secrets and variables → Actions). Sin este valor
# el endpoint POST /api/cron/maintenance devuelve 503.
# Generar con: openssl rand -hex 32
CRON_SECRET=""

# ─────────────────────────────────────────
# SEO / Branding — Fase 36
# ─────────────────────────────────────────
# Dominio canónico usado por metadataBase, sitemap.xml y robots.txt.
# Si vacío, cae a "https://erp.simtechgt.com".
NEXT_PUBLIC_SITE_URL="https://erp.simtechgt.com"

# ─────────────────────────────────────────
# Seed (solo dev/CI; NUNCA setear en prod)
# ─────────────────────────────────────────
# Si está en "true", el seed puede correr `deleteMany` global. En producción
# debe quedar vacío. El guard del seed (prisma/seed.ts) bloquea ejecución
# cuando NODE_ENV=production sin importar este flag.
ALLOW_SEED_DESTRUCTIVE=""
SEED_SUPERADMIN_EMAIL=""
SEED_SUPERADMIN_PASSWORD=""
SEED_COMPANY_ADMIN_EMAIL=""
SEED_COMPANY_ADMIN_PASSWORD=""
SEED_MANAGER_PASSWORD=""
SEED_CASHIER_PASSWORD=""
