# Fase 25-3a · Variables para integration tests.
#
# Apuntan a la DB efímera de docker-compose.test.yml (puerto 5433).
# NO son secretos reales — todo es stub. NO usar estos valores en otros
# entornos. El guard de vitest.integration.setup.ts aborta si
# DATABASE_URL no apunta a `simtech_test` o `localhost:5433`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/simtech_test?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5433/simtech_test?schema=public
NEXTAUTH_SECRET=integration-test-secret-32-chars-min-1234
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://stub.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=stub_anon_key
SUPABASE_SERVICE_ROLE_KEY=stub_service_role_key
ALLOW_SEED_DESTRUCTIVE=true
